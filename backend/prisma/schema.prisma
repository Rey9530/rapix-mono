// Prisma 7 — generator `prisma-client` (ESM) + driver adapter `@prisma/adapter-pg`
// En Prisma 7 el URL se pasa via `prisma.config.ts` (CLI/migrate) y via
// driver adapter `@prisma/adapter-pg` (runtime, ver `src/prisma/prisma.servicio.ts`).

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS — Usuarios y Autenticación
// ============================================================

enum RolUsuario {
  ADMIN
  VENDEDOR
  REPARTIDOR
  CLIENTE
}

enum EstadoUsuario {
  ACTIVO
  INACTIVO
  SUSPENDIDO
  PENDIENTE_VERIFICACION
}

// ============================================================
// ENUMS — Pedidos (Fase 3)
// ============================================================

enum EstadoPedido {
  PENDIENTE_ASIGNACION
  ASIGNADO
  RECOGIDO
  EN_TRANSITO
  EN_PUNTO_INTERCAMBIO
  EN_REPARTO
  ENTREGADO
  CANCELADO
  FALLIDO
  DEVUELTO
}

enum MetodoPago {
  CONTRA_ENTREGA
  PREPAGADO
  TARJETA
  TRANSFERENCIA
}

enum ModoFacturacion {
  POR_ENVIO
  PAQUETE
}

// ============================================================
// ENUMS — Paquetes Prepago (Fase 4)
// ============================================================

enum EstadoPaquete {
  ACTIVO
  PENDIENTE_PAGO
  AGOTADO
  EXPIRADO
  CANCELADO
}

// ============================================================
// ENUMS — Cierre Financiero (Fase 5)
// ============================================================

enum EstadoCierreFinanciero {
  PENDIENTE_REVISION
  APROBADO
  RECHAZADO
  CON_DISCREPANCIA
}

// ============================================================
// ENUMS — Notificaciones (Fase 6)
// ============================================================

enum CanalNotificacion {
  PUSH
  WHATSAPP
  EMAIL
}

enum EstadoNotificacion {
  PENDIENTE
  ENVIADO
  FALLIDO
  LEIDO
}

enum PlataformaDispositivo {
  ANDROID
  IOS
  WEB
}

// ============================================================
// MODELOS — Usuarios y Autenticación
// ============================================================

model Usuario {
  id              String        @id @default(uuid())
  email           String        @unique
  telefono        String        @unique
  hashContrasena  String
  nombreCompleto  String
  rol             RolUsuario
  estado          EstadoUsuario @default(PENDIENTE_VERIFICACION)
  urlAvatar       String?
  ultimoIngresoEn DateTime?
  creadoEn        DateTime      @default(now())
  actualizadoEn   DateTime      @updatedAt

  perfilAdmin        PerfilAdmin?
  perfilVendedor     PerfilVendedor?
  perfilRepartidor   PerfilRepartidor?
  tokensRefresco     TokenRefresco[]
  registrosAuditoria RegistroAuditoria[]
  notificaciones     Notificacion[]
  tokensDispositivo  TokenDispositivo[]

  @@index([rol, estado])
  @@map("usuarios")
}

model TokenRefresco {
  id          String    @id @default(uuid())
  usuarioId   String
  token       String    @unique
  expiraEn    DateTime
  revocadoEn  DateTime?
  userAgent   String?
  direccionIp String?
  creadoEn    DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("tokens_refresco")
}

model PerfilAdmin {
  id        String   @id @default(uuid())
  usuarioId String   @unique
  permisos  String[]

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("perfiles_admin")
}

// ============================================================
// PERFILES ESPECIALIZADOS — Fase 2
// ============================================================

model PerfilVendedor {
  id             String   @id @default(uuid())
  usuarioId      String   @unique
  nombreNegocio  String
  rfc            String?
  direccion      String
  latitud        Float
  longitud       Float
  urlLogo        String?
  saldoRecargado Int      @default(0)
  limiteCredito  Decimal  @default(0) @db.Decimal(10, 2)
  creadoEn       DateTime @default(now())
  actualizadoEn  DateTime @updatedAt

  usuario   Usuario            @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  pedidos   Pedido[]
  paquetes  PaqueteRecargado[]

  @@map("perfiles_vendedor")
}

model PerfilRepartidor {
  id                 String    @id @default(uuid())
  usuarioId          String    @unique
  tipoVehiculo       String
  placa              String?
  documentoIdentidad String
  telefonoEmergencia String?
  disponible         Boolean   @default(true)
  latitudActual      Float?
  longitudActual     Float?
  ultimaUbicacionEn  DateTime?
  calificacion       Float     @default(5.0)
  totalEntregas      Int       @default(0)
  creadoEn           DateTime  @default(now())
  actualizadoEn      DateTime  @updatedAt

  usuario            Usuario            @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  zonas              ZonaRepartidor[]
  pedidosRecogida    Pedido[]           @relation("RepartidorRecogida")
  pedidosEntrega     Pedido[]           @relation("RepartidorEntrega")
  cierresFinancieros CierreFinanciero[]

  @@map("perfiles_repartidor")
}

// ============================================================
// ZONAS GEOGRÁFICAS — Fase 2
//
// La columna `poligono` usa PostGIS (`geometry(Polygon, 4326)`) como
// tipo `Unsupported`. Todas las escrituras van por `$executeRawUnsafe`
// con `ST_GeomFromGeoJSON`; las lecturas serializan con `ST_AsGeoJSON`.
// Prisma client excluye por defecto las columnas `Unsupported`.
// ============================================================

model PuntoIntercambio {
  id            String   @id @default(uuid())
  nombre        String
  direccion     String
  latitud       Float
  longitud      Float
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  zonas Zona[]

  @@map("puntos_intercambio")
}

model Zona {
  id                 String                                    @id @default(uuid())
  codigo             String                                    @unique
  nombre             String
  descripcion        String?
  poligono           Unsupported("geometry(Polygon, 4326)")?
  latitudCentro      Float
  longitudCentro     Float
  puntoIntercambioId String?
  activa             Boolean                                   @default(true)
  creadoEn           DateTime                                  @default(now())
  actualizadoEn      DateTime                                  @updatedAt

  puntoIntercambio PuntoIntercambio? @relation(fields: [puntoIntercambioId], references: [id])
  repartidores     ZonaRepartidor[]
  pedidosOrigen    Pedido[]          @relation("PedidoZonaOrigen")
  pedidosDestino   Pedido[]          @relation("PedidoZonaDestino")

  @@index([activa])
  @@map("zonas")
}

model ZonaRepartidor {
  repartidorId String
  zonaId       String
  esPrimaria   Boolean  @default(false)
  creadoEn     DateTime @default(now())

  repartidor PerfilRepartidor @relation(fields: [repartidorId], references: [id], onDelete: Cascade)
  zona       Zona             @relation(fields: [zonaId], references: [id], onDelete: Cascade)

  @@id([repartidorId, zonaId])
  @@map("zonas_repartidor")
}

// ============================================================
// PEDIDOS — Fase 3
// ============================================================

model Pedido {
  id                String       @id @default(uuid())
  codigoSeguimiento String       @unique
  vendedorId        String
  estado            EstadoPedido @default(PENDIENTE_ASIGNACION)

  nombreCliente   String
  telefonoCliente String
  emailCliente    String?

  direccionOrigen String
  latitudOrigen   Float
  longitudOrigen  Float
  zonaOrigenId    String?
  notasOrigen     String?

  direccionDestino String
  latitudDestino   Float
  longitudDestino  Float
  zonaDestinoId    String?
  notasDestino     String?

  descripcionPaquete String?
  pesoPaqueteKg      Decimal? @db.Decimal(6, 2)
  valorDeclarado     Decimal? @db.Decimal(10, 2)
  urlFotoPaquete     String?

  metodoPago         MetodoPago
  modoFacturacion    ModoFacturacion @default(POR_ENVIO)
  costoEnvio         Decimal         @db.Decimal(10, 2)
  montoContraEntrega Decimal?        @db.Decimal(10, 2)
  // FK opcional a PaqueteRecargado — el modelo llega en Fase 4.
  // Se declara como columna simple ahora; Fase 4 añade la @relation.
  paqueteRecargadoId String?

  repartidorRecogidaId String?
  repartidorEntregaId  String?

  programadoPara  DateTime?
  recogidoEn      DateTime?
  enIntercambioEn DateTime?
  entregadoEn     DateTime?
  canceladoEn     DateTime?
  motivoCancelado String?
  motivoFallo     String?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  vendedor           PerfilVendedor    @relation(fields: [vendedorId], references: [id])
  zonaOrigen         Zona?             @relation("PedidoZonaOrigen", fields: [zonaOrigenId], references: [id])
  zonaDestino        Zona?             @relation("PedidoZonaDestino", fields: [zonaDestinoId], references: [id])
  repartidorRecogida PerfilRepartidor? @relation("RepartidorRecogida", fields: [repartidorRecogidaId], references: [id])
  repartidorEntrega  PerfilRepartidor? @relation("RepartidorEntrega", fields: [repartidorEntregaId], references: [id])
  paqueteRecargado   PaqueteRecargado? @relation(fields: [paqueteRecargadoId], references: [id])

  eventos                  EventoPedido[]
  comprobantes             ComprobanteEntrega[]
  cierresFinancierosPedido CierreFinancieroPedido[]

  @@index([estado])
  @@index([vendedorId, creadoEn])
  @@index([repartidorRecogidaId])
  @@index([repartidorEntregaId])
  @@map("pedidos")
}

model EventoPedido {
  id       String       @id @default(uuid())
  pedidoId String
  estado   EstadoPedido
  actorId  String?
  latitud  Float?
  longitud Float?
  notas    String?
  creadoEn DateTime     @default(now())

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId, creadoEn])
  @@map("eventos_pedido")
}

model ComprobanteEntrega {
  id          String   @id @default(uuid())
  pedidoId    String
  urlFoto     String
  urlFirma    String?
  recibidoPor String?
  notas       String?
  latitud     Float?
  longitud    Float?
  creadoEn    DateTime @default(now())

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId])
  @@map("comprobantes_entrega")
}

// ============================================================
// PAQUETES PREPAGO Y TARIFAS — Fase 4
// ============================================================

model ReglaTarifa {
  id              String          @id @default(uuid())
  nombre          String
  modoFacturacion ModoFacturacion
  precioPorEnvio  Decimal?        @db.Decimal(10, 2)
  tamanoPaquete   Int?
  precioPaquete   Decimal?        @db.Decimal(10, 2)
  activa          Boolean         @default(true)
  validaDesde     DateTime        @default(now())
  validaHasta     DateTime?
  creadoEn        DateTime        @default(now())
  actualizadoEn   DateTime        @updatedAt

  paquetes PaqueteRecargado[]

  @@index([modoFacturacion, activa])
  @@map("reglas_tarifa")
}

model PaqueteRecargado {
  id              String        @id @default(uuid())
  vendedorId      String
  reglaTarifaId   String
  nombre          String
  enviosTotales   Int
  enviosRestantes Int
  precio          Decimal       @db.Decimal(10, 2)
  estado          EstadoPaquete @default(ACTIVO)
  compradoEn      DateTime      @default(now())
  expiraEn        DateTime?
  creadoEn        DateTime      @default(now())
  actualizadoEn   DateTime      @updatedAt

  vendedor    PerfilVendedor @relation(fields: [vendedorId], references: [id])
  reglaTarifa ReglaTarifa    @relation(fields: [reglaTarifaId], references: [id])
  pedidos     Pedido[]

  @@index([vendedorId, estado])
  @@map("paquetes_recargados")
}

// ============================================================
// CIERRE FINANCIERO DIARIO — Fase 5
// ============================================================

model CierreFinanciero {
  id                 String                 @id @default(uuid())
  repartidorId       String
  fechaCierre        DateTime               @db.Date
  montoEsperado      Decimal                @db.Decimal(12, 2)
  montoReportado     Decimal                @db.Decimal(12, 2)
  diferencia         Decimal                @db.Decimal(12, 2)
  urlComprobanteFoto String
  notas              String?
  estado             EstadoCierreFinanciero @default(PENDIENTE_REVISION)
  motivoRechazo      String?
  revisadoPor        String?
  revisadoEn         DateTime?
  creadoEn           DateTime               @default(now())
  actualizadoEn      DateTime               @updatedAt

  repartidor PerfilRepartidor         @relation(fields: [repartidorId], references: [id])
  pedidos    CierreFinancieroPedido[]

  @@unique([repartidorId, fechaCierre])
  @@index([fechaCierre, estado])
  @@map("cierres_financieros")
}

model CierreFinancieroPedido {
  cierreId String
  pedidoId String
  monto    Decimal @db.Decimal(10, 2)

  cierre CierreFinanciero @relation(fields: [cierreId], references: [id], onDelete: Cascade)
  pedido Pedido           @relation(fields: [pedidoId], references: [id])

  @@id([cierreId, pedidoId])
  @@map("cierres_financieros_pedidos")
}

// ============================================================
// AUDITORÍA — Fase 5 (Tarea 5.7)
// ============================================================

model RegistroAuditoria {
  id          String   @id @default(uuid())
  usuarioId   String?
  accion      String
  tipoEntidad String
  entidadId   String?
  metadatos   Json?
  creadoEn    DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([tipoEntidad, entidadId])
  @@index([usuarioId, creadoEn])
  @@map("registros_auditoria")
}

// ============================================================
// NOTIFICACIONES — Fase 6
//
// `usuarioId` es opcional para soportar destinatarios externos
// (cliente final del pedido) que no tienen Usuario en el sistema.
// En esos casos `destino` lleva el email o teléfono E.164.
// ============================================================

model Notificacion {
  id            String             @id @default(uuid())
  usuarioId     String?
  canal         CanalNotificacion
  estado        EstadoNotificacion @default(PENDIENTE)
  titulo        String
  cuerpo        String
  datos         Json?
  destino       String?
  enviadoEn     DateTime?
  leidoEn       DateTime?
  mensajeError  String?
  creadoEn      DateTime           @default(now())
  actualizadoEn DateTime           @updatedAt

  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([usuarioId, creadoEn])
  @@index([estado])
  @@map("notificaciones")
}

model TokenDispositivo {
  id            String                @id @default(uuid())
  usuarioId     String
  token         String                @unique
  plataforma    PlataformaDispositivo
  activo        Boolean               @default(true)
  creadoEn      DateTime              @default(now())
  actualizadoEn DateTime              @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, activo])
  @@map("tokens_dispositivo")
}
