// Prisma 7 — generator `prisma-client` (ESM) + driver adapter `@prisma/adapter-pg`
// En Prisma 7 el URL se pasa via `prisma.config.ts` (CLI/migrate) y via
// driver adapter `@prisma/adapter-pg` (runtime, ver `src/prisma/prisma.servicio.ts`).

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS — Usuarios y Autenticación
// ============================================================

enum RolUsuario {
  ADMIN
  VENDEDOR
  REPARTIDOR
  CLIENTE
}

enum EstadoUsuario {
  ACTIVO
  INACTIVO
  SUSPENDIDO
  PENDIENTE_VERIFICACION
}

enum TipoCuentaBancaria {
  AHORRO
  CORRIENTE
}

// ============================================================
// ENUMS — Pedidos (Fase 3)
// ============================================================

enum EstadoPedido {
  PENDIENTE_ASIGNACION
  ASIGNADO
  RECOGIDO
  EN_TRANSITO
  EN_PUNTO_INTERCAMBIO
  EN_REPARTO
  ENTREGADO
  CANCELADO
  FALLIDO
  DEVUELTO
}

enum MetodoPago {
  CONTRA_ENTREGA
  PREPAGADO
  TARJETA
  TRANSFERENCIA
}

enum ModoFacturacion {
  POR_ENVIO
  PAQUETE
}

// ============================================================
// ENUMS — Paquetes Prepago (Fase 4)
// ============================================================

enum EstadoPaquete {
  ACTIVO
  PENDIENTE_PAGO
  AGOTADO
  EXPIRADO
  CANCELADO
}

// ============================================================
// ENUMS — Cierre Financiero (Fase 5)
// ============================================================

enum EstadoCierreFinanciero {
  PENDIENTE_REVISION
  APROBADO
  RECHAZADO
  CON_DISCREPANCIA
}

enum TipoMovimientoCaja {
  COBRO_RECOGIDA
  COBRO_ENTREGA
}

// ============================================================
// ENUMS — Notificaciones (Fase 6)
// ============================================================

enum CanalNotificacion {
  PUSH
  WHATSAPP
  EMAIL
}

enum EstadoNotificacion {
  PENDIENTE
  ENVIADO
  FALLIDO
  LEIDO
}

enum PlataformaDispositivo {
  ANDROID
  IOS
  WEB
}

// ============================================================
// ENUMS — WhatsApp Baileys (Fase 8)
// ============================================================

enum EstadoSesionWhatsapp {
  DESCONECTADA
  ESPERANDO_QR
  CONECTADA
  EXPIRADA
  BANEADA
}

enum TipoChatWhatsapp {
  INDIVIDUAL
  GRUPO
}

enum DireccionMensajeWhatsapp {
  ENTRANTE
  SALIENTE
}

enum TipoMensajeWhatsapp {
  TEXTO
  IMAGEN
  VIDEO
  AUDIO
  DOCUMENTO
  STICKER
  UBICACION
  CONTACTO
  SISTEMA
}

enum EstadoMensajeWhatsapp {
  PENDIENTE
  ENVIADO
  ENTREGADO
  LEIDO
  FALLIDO
}

// ============================================================
// ENUMS — Confirmación de entrega por IA
// ============================================================

enum EstadoConfirmacionEntrega {
  INICIADA
  PROCESANDO
  REPREGUNTADA
  RESUELTA
  EXPIRADA
  FALLIDA
}

enum IntencionConfirmacion {
  CONFIRMA
  RECHAZA
  CONDICIONAL
  AMBIGUO
}

enum RolMensajeConfirmacion {
  SISTEMA
  CLIENTE
  BOT
}

enum EtapaConversacionEntrega {
  CONFIRMACION_INICIAL
  ESPERANDO_DIRECCION_ORIGINAL
  CONFIRMANDO_RECHAZO
  OFRECIENDO_UBICACION_ALTERNATIVA
  ESPERANDO_NUEVA_UBICACION
}

// ============================================================
// MODELOS — Usuarios y Autenticación
// ============================================================

model Usuario {
  id                 String        @id @default(uuid())
  email              String        @unique
  telefono           String        @unique
  hashContrasena     String
  nombreCompleto     String
  rol                RolUsuario
  estado             EstadoUsuario @default(PENDIENTE_VERIFICACION)
  urlAvatar          String?
  ultimoIngresoEn    DateTime?
  correoVerificadoEn DateTime?
  creadoEn           DateTime      @default(now())
  actualizadoEn      DateTime      @updatedAt

  perfilAdmin                   PerfilAdmin?
  perfilVendedor                PerfilVendedor?
  perfilRepartidor              PerfilRepartidor?
  tokensRefresco                TokenRefresco[]
  registrosAuditoria            RegistroAuditoria[]
  notificaciones                Notificacion[]
  tokensDispositivo             TokenDispositivo[]
  tokensVerificacionCorreo      TokenVerificacionCorreo[]
  tokensRecuperacionContrasena  TokenRecuperacionContrasena[]

  @@index([rol, estado])
  @@map("usuarios")
}

model TokenVerificacionCorreo {
  id        String    @id @default(uuid())
  usuarioId String
  tokenHash String    @unique
  expiraEn  DateTime
  usadoEn   DateTime?
  creadoEn  DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("tokens_verificacion_correo")
}

model TokenRecuperacionContrasena {
  id        String    @id @default(uuid())
  usuarioId String
  tokenHash String    @unique
  expiraEn  DateTime
  usadoEn   DateTime?
  intentos  Int       @default(0)
  creadoEn  DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("tokens_recuperacion_contrasena")
}

model TokenRefresco {
  id          String    @id @default(uuid())
  usuarioId   String
  token       String    @unique
  expiraEn    DateTime
  revocadoEn  DateTime?
  userAgent   String?
  direccionIp String?
  creadoEn    DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("tokens_refresco")
}

model PerfilAdmin {
  id        String   @id @default(uuid())
  usuarioId String   @unique
  permisos  String[]

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("perfiles_admin")
}

// ============================================================
// PERFILES ESPECIALIZADOS — Fase 2
// ============================================================

model PerfilVendedor {
  id             String   @id @default(uuid())
  usuarioId      String   @unique
  nombreNegocio  String
  rfc            String?
  direccion      String
  latitud        Float
  longitud       Float
  urlLogo        String?
  saldoRecargado Int      @default(0)
  limiteCredito  Decimal  @default(0) @db.Decimal(10, 2)
  creadoEn       DateTime @default(now())
  actualizadoEn  DateTime @updatedAt

  usuario          Usuario            @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  pedidos          Pedido[]
  paquetes         PaqueteRecargado[]
  cuentasBancarias CuentaBancaria[]
  depositos        DepositoVendedor[]

  @@map("perfiles_vendedor")
}

model Banco {
  id            String   @id @default(uuid())
  codigo        String   @unique
  nombre        String
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt        @map("actualizado_en")

  cuentas CuentaBancaria[]

  @@index([activo, nombre])
  @@map("bancos")
}

model CuentaBancaria {
  id               String             @id @default(uuid())
  perfilVendedorId String             @map("perfil_vendedor_id")
  bancoId          String             @map("banco_id")
  tipoCuenta       TipoCuentaBancaria @map("tipo_cuenta")
  numeroCuenta     String             @map("numero_cuenta")
  alias            String?
  esPrincipal      Boolean            @default(false) @map("es_principal")
  activa           Boolean            @default(true)
  creadoEn         DateTime           @default(now()) @map("creado_en")
  actualizadoEn    DateTime           @updatedAt        @map("actualizado_en")

  perfilVendedor PerfilVendedor @relation(fields: [perfilVendedorId], references: [id], onDelete: Cascade)
  banco          Banco          @relation(fields: [bancoId], references: [id])
  depositos      DepositoVendedor[]

  @@index([perfilVendedorId, activa])
  @@map("cuentas_bancarias")
}

model PerfilRepartidor {
  id                 String    @id @default(uuid())
  usuarioId          String    @unique
  tipoVehiculo       String
  placa              String?
  documentoIdentidad String
  telefonoEmergencia String?
  disponible         Boolean   @default(true)
  latitudActual      Float?
  longitudActual     Float?
  ultimaUbicacionEn  DateTime?
  calificacion       Float     @default(5.0)
  totalEntregas      Int       @default(0)
  creadoEn           DateTime  @default(now())
  actualizadoEn      DateTime  @updatedAt

  usuario            Usuario                    @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  zonas              ZonaRepartidor[]
  pedidosRecogida    Pedido[]                   @relation("RepartidorRecogida")
  pedidosEntrega     Pedido[]                   @relation("RepartidorEntrega")
  cierresFinancieros CierreFinanciero[]
  movimientosCaja    MovimientoCajaRepartidor[]

  @@map("perfiles_repartidor")
}

// ============================================================
// ZONAS GEOGRÁFICAS — Fase 2
//
// La columna `poligono` usa PostGIS (`geometry(Polygon, 4326)`) como
// tipo `Unsupported`. Todas las escrituras van por `$executeRawUnsafe`
// con `ST_GeomFromGeoJSON`; las lecturas serializan con `ST_AsGeoJSON`.
// Prisma client excluye por defecto las columnas `Unsupported`.
// ============================================================

model PuntoIntercambio {
  id            String   @id @default(uuid())
  nombre        String
  direccion     String
  latitud       Float
  longitud      Float
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  zonas Zona[]

  @@map("puntos_intercambio")
}

model Zona {
  id                 String                                    @id @default(uuid())
  codigo             String                                    @unique
  nombre             String
  descripcion        String?
  poligono           Unsupported("geometry(Polygon, 4326)")?
  latitudCentro      Float
  longitudCentro     Float
  puntoIntercambioId String?
  activa             Boolean                                   @default(true)
  radioMaxRelocalizacionMetros Int?
  creadoEn           DateTime                                  @default(now())
  actualizadoEn      DateTime                                  @updatedAt

  puntoIntercambio PuntoIntercambio? @relation(fields: [puntoIntercambioId], references: [id])
  repartidores     ZonaRepartidor[]
  pedidosOrigen    Pedido[]          @relation("PedidoZonaOrigen")
  pedidosDestino   Pedido[]          @relation("PedidoZonaDestino")

  @@index([activa])
  @@map("zonas")
}

model ZonaRepartidor {
  repartidorId String
  zonaId       String
  esPrimaria   Boolean  @default(false)
  creadoEn     DateTime @default(now())

  repartidor PerfilRepartidor @relation(fields: [repartidorId], references: [id], onDelete: Cascade)
  zona       Zona             @relation(fields: [zonaId], references: [id], onDelete: Cascade)

  @@id([repartidorId, zonaId])
  @@map("zonas_repartidor")
}

// ============================================================
// PEDIDOS — Fase 3
// ============================================================

model Pedido {
  id                String       @id @default(uuid())
  codigoSeguimiento String       @unique
  vendedorId        String
  estado            EstadoPedido @default(PENDIENTE_ASIGNACION)

  nombreCliente   String
  telefonoCliente String
  emailCliente    String?

  direccionOrigen String
  latitudOrigen   Float
  longitudOrigen  Float
  zonaOrigenId    String?
  notasOrigen     String?

  direccionDestino String
  latitudDestino   Float?
  longitudDestino  Float?
  zonaDestinoId    String?
  notasDestino     String?

  descripcionPaquete String?
  pesoPaqueteKg      Decimal? @db.Decimal(6, 2)
  valorDeclarado     Decimal? @db.Decimal(10, 2)
  urlFotoPaquete     String?

  metodoPago         MetodoPago
  modoFacturacion    ModoFacturacion @default(POR_ENVIO)
  costoEnvio         Decimal         @db.Decimal(10, 2)
  montoContraEntrega Decimal?        @db.Decimal(10, 2)
  // FK opcional a PaqueteRecargado — el modelo llega en Fase 4.
  // Se declara como columna simple ahora; Fase 4 añade la @relation.
  paqueteRecargadoId String?

  repartidorRecogidaId String?
  repartidorEntregaId  String?

  // Liquidacion al vendedor (Fase 9) — null = pendiente; no-null = ya depositado.
  depositoId String?

  programadoPara  DateTime?
  recogidoEn      DateTime?
  enIntercambioEn DateTime?
  entregadoEn     DateTime?
  canceladoEn     DateTime?
  motivoCancelado String?
  motivoFallo     String?

  entregaConfirmada    Boolean?
  notaRider            String?
  fechaContactoCliente DateTime?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  vendedor           PerfilVendedor    @relation(fields: [vendedorId], references: [id])
  zonaOrigen         Zona?             @relation("PedidoZonaOrigen", fields: [zonaOrigenId], references: [id])
  zonaDestino        Zona?             @relation("PedidoZonaDestino", fields: [zonaDestinoId], references: [id])
  repartidorRecogida PerfilRepartidor? @relation("RepartidorRecogida", fields: [repartidorRecogidaId], references: [id])
  repartidorEntrega  PerfilRepartidor? @relation("RepartidorEntrega", fields: [repartidorEntregaId], references: [id])
  paqueteRecargado   PaqueteRecargado? @relation(fields: [paqueteRecargadoId], references: [id])
  deposito           DepositoVendedor? @relation(fields: [depositoId], references: [id], onDelete: SetNull)

  eventos             EventoPedido[]
  comprobantes        ComprobanteEntrega[]
  movimientosCaja     MovimientoCajaRepartidor[]
  confirmacionEntrega ConfirmacionEntregaConversacion?

  @@index([estado])
  @@index([vendedorId, creadoEn])
  @@index([repartidorRecogidaId])
  @@index([repartidorEntregaId])
  @@index([vendedorId, depositoId, metodoPago, estado])
  @@map("pedidos")
}

model EventoPedido {
  id       String       @id @default(uuid())
  pedidoId String
  estado   EstadoPedido
  actorId  String?
  latitud  Float?
  longitud Float?
  notas    String?
  creadoEn DateTime     @default(now())

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId, creadoEn])
  @@map("eventos_pedido")
}

model ComprobanteEntrega {
  id          String   @id @default(uuid())
  pedidoId    String
  urlFoto     String
  urlFirma    String?
  recibidoPor String?
  notas       String?
  latitud     Float?
  longitud    Float?
  creadoEn    DateTime @default(now())

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId])
  @@map("comprobantes_entrega")
}

// ============================================================
// PAQUETES PREPAGO Y TARIFAS — Fase 4
// ============================================================

model ReglaTarifa {
  id              String          @id @default(uuid())
  nombre          String
  modoFacturacion ModoFacturacion
  precioPorEnvio  Decimal?        @db.Decimal(10, 2)
  tamanoPaquete   Int?
  precioPaquete   Decimal?        @db.Decimal(10, 2)
  activa          Boolean         @default(true)
  validaDesde     DateTime        @default(now())
  validaHasta     DateTime?
  creadoEn        DateTime        @default(now())
  actualizadoEn   DateTime        @updatedAt

  paquetes PaqueteRecargado[]

  @@index([modoFacturacion, activa])
  @@map("reglas_tarifa")
}

model PaqueteRecargado {
  id                  String        @id @default(uuid())
  vendedorId          String
  reglaTarifaId       String
  nombre              String
  enviosTotales       Int
  enviosRestantes     Int
  precio              Decimal       @db.Decimal(10, 2)
  estado              EstadoPaquete @default(ACTIVO)
  metodoPago          MetodoPago?
  urlComprobantePago  String?
  comprobanteSubidoEn DateTime?
  compradoEn          DateTime      @default(now())
  expiraEn            DateTime?
  creadoEn            DateTime      @default(now())
  actualizadoEn       DateTime      @updatedAt

  vendedor    PerfilVendedor @relation(fields: [vendedorId], references: [id])
  reglaTarifa ReglaTarifa    @relation(fields: [reglaTarifaId], references: [id])
  pedidos     Pedido[]

  @@index([vendedorId, estado])
  @@map("paquetes_recargados")
}

// ============================================================
// CIERRE FINANCIERO DIARIO — Fase 5
// ============================================================

model CierreFinanciero {
  id                 String                 @id @default(uuid())
  repartidorId       String
  fechaCierre        DateTime               @db.Date
  montoEsperado      Decimal                @db.Decimal(12, 2)
  montoReportado     Decimal                @db.Decimal(12, 2)
  diferencia         Decimal                @db.Decimal(12, 2)
  urlComprobanteFoto String
  notas              String?
  estado             EstadoCierreFinanciero @default(PENDIENTE_REVISION)
  motivoRechazo      String?
  revisadoPor        String?
  revisadoEn         DateTime?
  creadoEn           DateTime               @default(now())
  actualizadoEn      DateTime               @updatedAt

  repartidor  PerfilRepartidor           @relation(fields: [repartidorId], references: [id])
  movimientos MovimientoCajaRepartidor[]

  @@unique([repartidorId, fechaCierre])
  @@index([fechaCierre, estado])
  @@map("cierres_financieros")
}

model MovimientoCajaRepartidor {
  id           String             @id @default(uuid())
  repartidorId String
  pedidoId     String?
  cierreId     String?
  tipo         TipoMovimientoCaja
  monto        Decimal            @db.Decimal(10, 2)
  descripcion  String?
  creadoEn     DateTime           @default(now())

  repartidor PerfilRepartidor  @relation(fields: [repartidorId], references: [id])
  pedido     Pedido?           @relation(fields: [pedidoId], references: [id])
  cierre     CierreFinanciero? @relation(fields: [cierreId], references: [id])

  @@index([repartidorId, cierreId])
  @@index([repartidorId, creadoEn])
  @@map("movimientos_caja_repartidor")
}

// ============================================================
// LIQUIDACIONES A VENDEDORES — Fase 9
//
// Cada DepositoVendedor agrupa N pedidos CONTRA_ENTREGA cuyo
// montoContraEntrega ya fue trasladado al vendedor. Un Pedido se
// considera "pendiente de deposito" cuando depositoId IS NULL y
// "ya depositado" cuando depositoId IS NOT NULL.
// ============================================================

model DepositoVendedor {
  id               String   @id @default(uuid())
  vendedorId       String
  cuentaBancariaId String?
  monto            Decimal  @db.Decimal(12, 2)
  fechaDeposito    DateTime
  referencia       String?
  notas            String?
  urlComprobante   String?
  creadoEn         DateTime @default(now())
  actualizadoEn    DateTime @updatedAt

  vendedor       PerfilVendedor  @relation(fields: [vendedorId], references: [id], onDelete: Restrict)
  cuentaBancaria CuentaBancaria? @relation(fields: [cuentaBancariaId], references: [id], onDelete: SetNull)
  pedidos        Pedido[]

  @@index([vendedorId, fechaDeposito])
  @@map("depositos_vendedor")
}

// ============================================================
// AUDITORÍA — Fase 5 (Tarea 5.7)
// ============================================================

model RegistroAuditoria {
  id          String   @id @default(uuid())
  usuarioId   String?
  accion      String
  tipoEntidad String
  entidadId   String?
  metadatos   Json?
  creadoEn    DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([tipoEntidad, entidadId])
  @@index([usuarioId, creadoEn])
  @@map("registros_auditoria")
}

// ============================================================
// NOTIFICACIONES — Fase 6
//
// `usuarioId` es opcional para soportar destinatarios externos
// (cliente final del pedido) que no tienen Usuario en el sistema.
// En esos casos `destino` lleva el email o teléfono E.164.
// ============================================================

model Notificacion {
  id            String             @id @default(uuid())
  usuarioId     String?
  canal         CanalNotificacion
  estado        EstadoNotificacion @default(PENDIENTE)
  titulo        String
  cuerpo        String
  datos         Json?
  destino       String?
  enviadoEn     DateTime?
  leidoEn       DateTime?
  mensajeError  String?
  creadoEn      DateTime           @default(now())
  actualizadoEn DateTime           @updatedAt

  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([usuarioId, creadoEn])
  @@index([estado])
  @@map("notificaciones")
}

model TokenDispositivo {
  id            String                @id @default(uuid())
  usuarioId     String
  token         String                @unique
  plataforma    PlataformaDispositivo
  activo        Boolean               @default(true)
  creadoEn      DateTime              @default(now())
  actualizadoEn DateTime              @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, activo])
  @@map("tokens_dispositivo")
}

// ============================================================
// WHATSAPP BAILEYS — Fase 8
//
// Sesion unica global (id = "global"). El auth state vive en una
// tabla key-value que reemplaza a `useMultiFileAuthState`.
// Los chats, mensajes, contactos, participantes de grupo y
// reacciones se persisten al recibir eventos de baileys.
// ============================================================

/// Fila unica (id = "global") con el estado de la sesion Baileys.
model SesionWhatsapp {
  id             String               @id
  estado         EstadoSesionWhatsapp @default(DESCONECTADA)
  jidPropio      String?
  numeroPropio   String?
  nombrePropio   String?
  qrActual       String?
  qrExpiraEn     DateTime?
  ultimoErrorEn  DateTime?
  ultimoError    String?
  conectadoEn    DateTime?
  desconectadoEn DateTime?
  creadoEn       DateTime             @default(now())
  actualizadoEn  DateTime             @updatedAt

  @@map("sesiones_whatsapp")
}

/// Tabla key-value para el AuthenticationState de baileys.
/// `tipo` es el "kind" baileys (creds | pre-key | session | sender-key | app-state-sync-key | ...).
model AuthStateWhatsapp {
  id            String   @id @default(uuid())
  sesionId      String
  tipo          String
  clave         String
  valor         Json
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([sesionId, tipo, clave])
  @@index([sesionId, tipo])
  @@map("auth_state_whatsapp")
}

/// Contacto sincronizado de WhatsApp.
model ContactoWhatsapp {
  id            String    @id @default(uuid())
  jid           String    @unique
  numero        String?
  nombre        String?
  urlAvatar     String?
  bloqueado     Boolean   @default(false)
  visto         DateTime?
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  participaciones ParticipanteGrupoWhatsapp[]
  mensajes        MensajeWhatsapp[]           @relation("MensajesPorContacto")

  @@index([numero])
  @@map("contactos_whatsapp")
}

/// Chat (1:1 o grupo).
model ChatWhatsapp {
  id              String           @id @default(uuid())
  jid             String           @unique
  tipo            TipoChatWhatsapp
  nombre          String?
  urlAvatar       String?
  ultimoMensajeEn DateTime?
  ultimoMensajeId String?
  noLeidos        Int              @default(0)
  archivado       Boolean          @default(false)
  silenciadoHasta DateTime?
  creadoEn        DateTime         @default(now())
  actualizadoEn   DateTime         @updatedAt

  mensajes              MensajeWhatsapp[]
  participantes         ParticipanteGrupoWhatsapp[]
  confirmacionesEntrega ConfirmacionEntregaConversacion[]

  @@index([tipo, ultimoMensajeEn])
  @@index([archivado, ultimoMensajeEn])
  @@map("chats_whatsapp")
}

/// Participantes de un chat de grupo (snapshot derivado de baileys).
model ParticipanteGrupoWhatsapp {
  id           String   @id @default(uuid())
  chatId       String
  contactoId   String
  esAdmin      Boolean  @default(false)
  esSuperAdmin Boolean  @default(false)
  creadoEn     DateTime @default(now())

  chat     ChatWhatsapp     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  contacto ContactoWhatsapp @relation(fields: [contactoId], references: [id], onDelete: Cascade)

  @@unique([chatId, contactoId])
  @@index([chatId])
  @@map("participantes_grupo_whatsapp")
}

/// Mensaje individual.
model MensajeWhatsapp {
  id            String                   @id @default(uuid())
  /// `key.id` que asigna baileys; unico dentro del chat (idempotencia).
  externoId     String
  chatId        String
  /// Contacto remitente (en grupos puede diferir del chat). En SALIENTE = null.
  remitenteId   String?
  direccion     DireccionMensajeWhatsapp
  tipo          TipoMensajeWhatsapp
  estado        EstadoMensajeWhatsapp    @default(PENDIENTE)

  texto         String?
  caption       String?
  urlMedia      String?
  mimeMedia     String?
  bytesMedia    Int?
  duracionSeg   Int?
  nombreArchivo String?
  miniatura     String?

  /// Mensaje al que responde (replyTo). Self-relation opcional.
  respondeAId String?
  reenviado   Boolean @default(false)

  enviadoEn   DateTime?
  entregadoEn DateTime?
  leidoEn     DateTime?
  fallaError  String?

  /// Payload original de baileys por si se necesita re-procesar.
  payloadCrudo Json?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  chat                     ChatWhatsapp                     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  remitente                ContactoWhatsapp?                @relation("MensajesPorContacto", fields: [remitenteId], references: [id], onDelete: SetNull)
  respondeA                MensajeWhatsapp?                 @relation("RespuestaMensaje", fields: [respondeAId], references: [id], onDelete: SetNull)
  respuestas               MensajeWhatsapp[]                @relation("RespuestaMensaje")
  reacciones               ReaccionMensajeWhatsapp[]
  intercambiosConfirmacion ConfirmacionEntregaIntercambio[]

  @@unique([chatId, externoId])
  @@index([chatId, creadoEn])
  @@index([direccion, estado])
  @@map("mensajes_whatsapp")
}

/// Reacciones a mensajes (un autor puede reaccionar a un mensaje con un emoji; ultima gana).
model ReaccionMensajeWhatsapp {
  id            String   @id @default(uuid())
  mensajeId     String
  /// jid de quien reacciona (puede ser nuestro propio jid).
  jidAutor      String
  emoji         String?
  reaccionadoEn DateTime @default(now())

  mensaje MensajeWhatsapp @relation(fields: [mensajeId], references: [id], onDelete: Cascade)

  @@unique([mensajeId, jidAutor])
  @@index([mensajeId])
  @@map("reacciones_mensaje_whatsapp")
}

// ============================================================
// MODELOS — Confirmacion de entrega por IA (WhatsApp + OpenAI)
//
// Al pasar un pedido a RECOGIDO, se crea una conversacion 1:1 con el cliente
// final. Cada turno (saliente del bot o entrante del cliente) se registra
// como un intercambio para auditoria y para alimentar el contexto a OpenAI
// en respuestas posteriores.
// ============================================================

model ConfirmacionEntregaConversacion {
  id                          String                    @id @default(uuid())
  pedidoId                    String                    @unique
  chatId                      String?
  estado                      EstadoConfirmacionEntrega @default(INICIADA)
  etapa                       EtapaConversacionEntrega  @default(CONFIRMACION_INICIAL)
  intencionFinal              IntencionConfirmacion?
  iniciadaEn                  DateTime                  @default(now())
  resueltaEn                  DateTime?
  vencimientoNotificacionEn   DateTime
  notificacionVendedorEnviada Boolean                   @default(false)
  motivoFalla                 String?
  latitudOriginal             Float?
  longitudOriginal            Float?
  latitudPropuesta            Float?
  longitudPropuesta           Float?
  creadoEn                    DateTime                  @default(now())
  actualizadoEn               DateTime                  @updatedAt

  pedido       Pedido                          @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  chat         ChatWhatsapp?                   @relation(fields: [chatId], references: [id], onDelete: SetNull)
  intercambios ConfirmacionEntregaIntercambio[]

  @@index([estado, vencimientoNotificacionEn, notificacionVendedorEnviada])
  @@index([chatId, estado])
  @@map("confirmaciones_entrega_conversacion")
}

model ConfirmacionEntregaIntercambio {
  id                   String                  @id @default(uuid())
  conversacionId       String
  rol                  RolMensajeConfirmacion
  texto                String
  mensajeWhatsappId    String?
  intencionClasificada IntencionConfirmacion?
  creadoEn             DateTime                @default(now())

  conversacion    ConfirmacionEntregaConversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  mensajeWhatsapp MensajeWhatsapp?                @relation(fields: [mensajeWhatsappId], references: [id], onDelete: SetNull)

  @@index([conversacionId, creadoEn])
  @@map("confirmacion_entrega_intercambios")
}
