# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:4200

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/delivery?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (mínimo 32 caracteres)
JWT_ACCESS_SECRET=change-me-access-change-me-access-change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change-me-refresh-change-me-refresh-change
JWT_REFRESH_EXPIRES=30d

# Mapbox
MAPBOX_TOKEN=pk.xxxxx

# WhatsApp Cloud API (Meta) — DEPRECADO: el canal WHATSAPP ahora usa Baileys
# (ver bloque "WhatsApp Baileys" mas abajo). Estas variables se mantienen
# temporalmente para no romper despliegues con .env existentes; pueden
# eliminarse cuando todos los entornos hayan migrado.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v20.0

# SMTP (nodemailer) — Mailhog en dev, SES/Postfix en prod.
# DEPRECADO: queda como fallback temporal mientras Mailgun se estabiliza
# (controlado por MAIL_DRIVER mas abajo). Se eliminara en una tarea posterior.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@delivery.com
SMTP_FROM_NAME="Rapix"

# Mail driver — alterna entre el adaptador Mailgun (default) y el SMTP legacy.
# Cambiar a `smtp` y reiniciar revierte al transporte nodemailer sin redeploy.
MAIL_DRIVER=mailgun

# Mailgun (HTTP API). Requeridos cuando MAIL_DRIVER=mailgun.
# Crear el dominio en https://app.mailgun.com/app/sending/domains y copiar la
# API key desde Account Settings > API Security. NUNCA commitear .env real.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.rapixapp.com
MAILGUN_REGION=us
MAILGUN_FROM="Rapix <no-reply@mg.rapixapp.com>"
MAILGUN_SANDBOX=false

# Firebase (FCM) — Service Account del proyecto rapix-a0117.
# Generar con Firebase Console → Project settings → Service accounts → Generate new private key.
# La FIREBASE_PRIVATE_KEY debe ir entre comillas dobles y con \n literales (NO con saltos de linea reales).
# Ejemplo: FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# MinIO (S3-compatible, self-hosted)
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_UPLOADS=delivery-uploads
MINIO_PUBLIC_URL=http://localhost:9000/delivery-uploads

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Notificaciones — limite anti-spam por usuario por hora (rate-limit via Redis).
# Cuando un usuario excede este numero en 1 hora, las siguientes notificaciones
# se persisten como FALLIDO con mensajeError=RATE_LIMIT_EXCEDIDO. Default: 20.
NOTIFICACIONES_LIMITE_HORA=20

# WhatsApp Baileys (Fase 8)
# La sesion unica global; las credenciales se persisten en Postgres.
WHATSAPP_BAILEYS_HABILITADO=true
WHATSAPP_BAILEYS_NAVEGADOR_NOMBRE=Rapix
WHATSAPP_BAILEYS_TASA_MAX_POR_SEG=1
WHATSAPP_BAILEYS_RAFAGA_MAX=5
WHATSAPP_BAILEYS_LOG_LEVEL=warn

# Confirmacion de entrega por IA (OpenAI)
# Al pasar un pedido a RECOGIDO, un bot contacta al cliente por WhatsApp,
# clasifica su respuesta y deja una nota visible para el repartidor. Si el
# cliente no responde en CONFIRMACION_ENTREGA_TIMEOUT_MINUTOS, se avisa al
# vendedor por FCM. Sin OPENAI_API_KEY el clasificador degrada a AMBIGUO.
OPENAI_API_KEY=
OPENAI_MODEL_CONFIRMACION_ENTREGA=gpt-4o-mini
CONFIRMACION_ENTREGA_TIMEOUT_MINUTOS=60
